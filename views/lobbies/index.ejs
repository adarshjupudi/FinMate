<% layout('layouts/boilerplate') %>

<div class="container py-5 animate-fade-in" style="max-width: 1000px;">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <a href="/" class="btn btn-finmate-outline btn-sm px-3 rounded-pill d-flex align-items-center gap-2">
            <i class="bi bi-arrow-left"></i> Dashboard
        </a>
        <h3 class="fw-bold m-0" style="color: var(--finmate-purple-heading);"><i class="bi bi-basket-fill"></i> Delivery Carts</h3>
    </div>

    <div class="row g-4">
        <div class="col-lg-4 col-12">
            <div class="card border shadow-sm" style="background-color: var(--finmate-card-bg); border-radius: 16px; position: sticky; top: 24px;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3" style="color: var(--finmate-purple-heading);">Host a New Pool</h5>
                    
                    <form action="/lobbies" method="POST">
                        <div class="mb-3">
                            <label class="form-label small fw-medium">App/Store Name</label>
                            <input type="text" class="form-control" name="storeName" placeholder="Zomato - Canteen" required style="border-radius: 8px;">
                        </div>
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <label class="form-label small fw-medium">Goal (₹)</label>
                                <input type="number" class="form-control" name="targetAmount" value="399" min="1" required style="border-radius: 8px;">
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-medium text-danger">Wait Time (Mins)</label>
                                <input type="number" class="form-control border-danger-subtle" name="duration" value="10" min="1" max="60" required style="border-radius: 8px;">
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-medium">Your Item Cost (₹)</label>
                            <input type="number" class="form-control" name="initialItemCost" placeholder="180" min="1" required style="border-radius: 8px;">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-medium">Your Items Description</label>
                            <textarea class="form-control" name="initialItemDesc" rows="2" placeholder="Chicken Biryani" required style="border-radius: 8px;"></textarea>
                        </div>
                        <button type="submit" class="btn btn-finmate-solid w-100 fw-bold rounded-pill">Open Cart & Notify Friends</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-8 col-12">
            <% if (lobbies && lobbies.length > 0) { %>
                <div class="d-flex flex-column gap-4">
                    <% lobbies.forEach(lobby => { 
                        const progress = Math.min(Math.round((lobby.currentAmount / lobby.targetAmount) * 100), 100); 
                        const met = lobby.currentAmount >= lobby.targetAmount;
                        const statusColor = met ? 'text-success' : 'text-warning';
                        
                        const expiryTime = new Date(lobby.createdAt).getTime() + (lobby.duration * 60000);
                        const minsLeft = Math.max(0, Math.floor((expiryTime - Date.now()) / 60000));

                        // LINTER FIX: Extracting dynamic tags into pure strings
                        const statusText = met ? 'Target Unlocked!' : '₹' + (lobby.targetAmount - lobby.currentAmount) + ' Remaining';
                        const statusHTML = '<span class="fw-bold d-block ' + statusColor + '">' + statusText + '</span>';
                        const barHTML = '<div class="progress-bar bg-primary" role="progressbar" data-width="' + progress + '"></div>';
                    %>
                        <div class="card border shadow-sm bg-body" style="border-radius: 16px;">
                            <div class="card-header border-bottom bg-transparent p-4 d-flex justify-content-between align-items-start">
                                <div>
                                    <span class="badge bg-primary-subtle text-primary mb-1 rounded-pill">Host: @<%= lobby.host.username %></span>
                                    <h4 class="fw-bold m-0 text-dark"><%= lobby.storeName %></h4>
                                </div>
                                <div class="text-end">
                                    <span class="badge bg-danger rounded-pill mb-1"><i class="bi bi-stopwatch"></i> <%= minsLeft %> Mins Left</span>
                                    <%- statusHTML %>
                                </div>
                            </div>
                            
                            <div class="card-body p-4">
                                <div class="progress mb-4" style="height: 10px; border-radius: 6px; background-color: var(--finmate-border);">
                                    <%- barHTML %>
                                </div>

                                <div class="d-flex flex-column gap-2 mb-4">
                                    <% lobby.members.forEach(member => { %>
                                        <div class="p-3 border rounded-3 bg-light-subtle d-flex justify-content-between align-items-center">
                                            <div><span class="small fw-bold d-block">@<%= member.user.username %> added:</span><span class="small text-secondary"><%= member.itemsDescription %></span></div>
                                            <span class="fw-bold text-primary">₹<%= member.itemCost %></span>
                                        </div>
                                    <% }) %>
                                </div>

                                <div class="border-top pt-3">
                                    <% if (currentUser._id.toString() === lobby.host._id.toString()) { %>
                                        <form action="/lobbies/<%= lobby._id %>/close" method="POST" class="m-0"><button type="submit" class="btn btn-outline-danger btn-sm px-4 w-100 fw-bold rounded-pill">Close & Order Now</button></form>
                                    <% } else { %>
                                        <button class="btn btn-finmate-solid btn-sm px-4 w-100 fw-bold rounded-pill" data-bs-toggle="collapse" data-bs-target="#join_form_<%= lobby._id %>">Merge Items Into Cart</button>
                                        <div class="collapse mt-3" id="join_form_<%= lobby._id %>">
                                            <div class="p-3 border rounded-3 bg-light-subtle">
                                                <form action="/lobbies/<%= lobby._id %>/join" method="POST">
                                                    <div class="row g-2">
                                                        <div class="col-4"><input type="number" class="form-control form-control-sm" name="itemCost" placeholder="Cost (₹)" required></div>
                                                        <div class="col-6"><input type="text" class="form-control form-control-sm" name="itemsDescription" placeholder="Item Name" required></div>
                                                        <div class="col-2"><button type="submit" class="btn btn-sm btn-success w-100 fw-bold">Add</button></div>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="text-center py-5 border border-dashed bg-body" style="border-radius: 16px;"><p class="text-secondary small">No active cart lobbies.</p></div>
            <% } %>
        </div>
    </div>
</div>

<script>
document.querySelectorAll('.progress-bar[data-width]').forEach(bar => {
    const width = bar.getAttribute('data-width');
    bar.style.width = width + '%';
    bar.style.backgroundColor = 'var(--finmate-purple-heading)';
});
</script>