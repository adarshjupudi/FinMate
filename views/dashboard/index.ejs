<%- layout('layouts/boilerplate') %>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="bg-white p-4 rounded shadow-sm d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="fw-bold mb-1">Hey, <%= currentUser ? currentUser.username : 'User' %>!</h2>
                    <p class="text-muted mb-0">Welcome back to your campus workspace.</p>
                </div>
                <div>
                    <a href="/logout" class="btn btn-outline-danger fw-bold btn-sm">Log Out</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex align-items-center mb-3">
                            <h5 class="card-title fw-bold mb-0">Wallet and Expenses</h5>
                        </div>
                        <h3 class="fw-bold text-success mb-2">INR <%= currentUser ? currentUser.allowance : 0 %></h3>
                        <p class="card-text text-muted small">Current monthly budget limit. Set your allowance below to track metrics.</p>
                    </div>
                    <form action="/dashboard/allowance" method="POST" class="mt-3">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text">INR</span>
                            <input type="number" name="allowance" class="form-control" placeholder="Update budget" min="0" required>
                            <button class="btn btn-success fw-bold">Set</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card h-100 border-0 shadow-sm opacity-75">
                <div class="card-body">
                    <h5 class="card-title fw-bold mb-3">Wingman Ledger</h5>
                    <h3 class="fw-bold text-primary mb-2">INR 0</h3>
                    <p class="card-text text-muted small">Peer transaction splitting loops. Locked until Phase 2.</p>
                    <button class="btn btn-sm btn-outline-primary w-100 fw-bold disabled mt-auto">Manage Circles</button>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card h-100 border-0 shadow-sm opacity-75">
                <div class="card-body">
                    <h5 class="card-title fw-bold mb-3">Flash Delivery Pool</h5>
                    <h3 class="fw-bold text-warning mb-2">0 Lobbies</h3>
                    <p class="card-text text-muted small">Coordinate cart minimums. Locked until Phase 3.</p>
                    <button class="btn btn-sm btn-outline-warning w-100 fw-bold disabled mt-auto">Open Lobby</button>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card h-100 border-0 shadow-sm opacity-75">
                <div class="card-body">
                    <h5 class="card-title fw-bold mb-3">Ghost Flag Tracker</h5>
                    <h3 class="fw-bold text-danger mb-2">INR 0 Wasted</h3>
                    <p class="card-text text-muted small">Background scanning cron engines. Locked until Phase 1 End.</p>
                    <button class="btn btn-sm btn-outline-danger w-100 fw-bold disabled mt-auto">Audit Plans</button>
                </div>
            </div>
        </div>
    </div>
</div>