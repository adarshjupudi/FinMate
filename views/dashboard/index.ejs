<% layout('layouts/boilerplate') %>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="container-fluid py-4 px-4 animate-fade-in">
    
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 position-relative overflow-hidden" style="background: linear-gradient(135deg, var(--finmate-purple-heading), var(--finmate-purple-dark)); color: #FFFFFF;">
                <div class="card-body p-4 d-flex flex-column flex-sm-row justify-content-between align-items-sm-center z-1 position-relative">
                    <div class="mb-3 mb-sm-0">
                        <span class="text-white-50 text-uppercase tracking-wider small fw-bold d-block mb-1">Available Campus Balance</span>
                        <h1 class="display-4 fw-bold m-0">₹<%= currentUser.allowance || 0 %></h1>
                    </div>
                    <div class="d-flex gap-3 flex-wrap align-items-center">
                        <form action="/reset-funds" method="POST" class="m-0 p-0" onsubmit="return confirm('Are you sure you want to completely clear your remaining allowance? This sets your available balance back to ₹0.');">
                            <button type="submit" class="btn btn-light text-dark fw-bold px-3 py-2 d-inline-flex align-items-center gap-2 shadow-sm" style="border-radius: 8px; height: 44px;">
                                <i class="bi bi-arrow-counterclockwise"></i> Reset Funds
                            </button>
                        </form>
                        <button class="btn btn-light text-dark fw-bold px-4 py-2 d-inline-flex align-items-center gap-2 shadow-sm" data-bs-toggle="modal" data-bs-target="#addFundsModal" style="border-radius: 8px; height: 44px;">
                            <i class="bi bi-cash-coin" style="color: var(--finmate-purple-heading);"></i> Add Funds
                        </button>
                        <button class="btn btn-light text-dark fw-bold px-4 py-2 d-inline-flex align-items-center gap-2 shadow-sm" data-bs-toggle="modal" data-bs-target="#addExpenseModal" style="border-radius: 8px; height: 44px;">
                            <i class="bi bi-plus-circle-fill" style="color: var(--finmate-purple-heading);"></i> Log Expense
                        </button>
                    </div>
                </div>
                <div class="position-absolute end-0 top-50 translate-middle-y opacity-10 pe-5 d-none d-md-block">
                    <i class="bi bi-wallet2" style="font-size: 12rem; color: #FFFFFF;"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        
        <div class="col-xl-7 col-lg-12">
            <div class="card border shadow-sm h-100" style="background-color: var(--finmate-card-bg); border-radius: 16px;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h5 class="fw-bold m-0" style="color: var(--finmate-purple-heading);">1. Money Tracker & Analysis</h5>
                            <small class="text-secondary">Chronological ledger of outlays and credits</small>
                        </div>
                        <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill fw-medium">Active Analytics</span>
                    </div>

                    <% if(typeof expenses !== 'undefined' && expenses.length > 0 && analytics) { %>
                        <div id="analyticsDataBridge" 
                             data-canteen="<%= analytics.categoryTotals['Canteen'] %>"
                             data-academics="<%= analytics.categoryTotals['Academics'] %>"
                             data-travel="<%= analytics.categoryTotals['Travel'] %>"
                             data-junkfood="<%= analytics.categoryTotals['Junk Food'] %>"
                             data-other="<%= analytics.categoryTotals['Other'] %>"
                             style="display: none;"></div>

                        <div class="row g-4 mb-4">
                            <div class="col-sm-6">
                                <div class="p-3 rounded-3 border bg-body shadow-sm d-flex align-items-center justify-content-between">
                                    <div>
                                        <span class="text-secondary small fw-medium d-block">Total Outlays</span>
                                        <h4 class="fw-bold m-0 text-danger">₹<%= analytics.totalSpent %></h4>
                                    </div>
                                    <i class="bi bi-pie-chart-fill fs-3 opacity-50"></i>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3 rounded-3 border bg-body shadow-sm d-flex align-items-center justify-content-between">
                                    <div>
                                        <span class="text-secondary small fw-medium d-block">Avg / Transaction</span>
                                        <h4 class="fw-bold m-0" style="color: var(--finmate-purple-heading);">₹<%= analytics.avgExpense %></h4>
                                    </div>
                                    <i class="bi bi-calculator fs-3 opacity-50"></i>
                                </div>
                            </div>
                        </div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <h6 class="fw-bold small text-secondary text-uppercase tracking-wider mb-3">Transaction History</h6>
                                <div class="d-flex flex-column gap-3" style="max-height: 310px; overflow-y: auto; padding-right: 4px;">
                                    
                                    <% expenses.forEach(expense => { %>
                                        <div class="p-3 border d-flex align-items-center justify-content-between bg-body rounded-3 shadow-sm-hover">
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="rounded-circle d-flex align-items-center justify-content-center border bg-light" style="width: 36px; height: 36px; flex-shrink: 0;">
                                                    <% if(expense.splitType === 'Settlement') { %><i class="bi bi-arrow-down-left text-success fs-6"></i>
                                                    <% } else if(expense.splitType === 'Equi-Split' || expense.splitType === 'Custom Split') { %><i class="bi bi-pie-chart text-primary fs-6"></i>
                                                    <% } else if(expense.category === 'Canteen') { %><i class="bi bi-cup-hot text-primary fs-6"></i>
                                                    <% } else if(expense.category === 'Academics') { %><i class="bi bi-book text-primary fs-6"></i>
                                                    <% } else if(expense.category === 'Travel') { %><i class="bi bi-car-front text-primary fs-6"></i>
                                                    <% } else if(expense.category === 'Junk Food') { %><i class="bi bi-egg-fried text-primary fs-6"></i>
                                                    <% } else { %><i class="bi bi-tag text-primary fs-6"></i><% } %>
                                                </div>
                                                <div style="min-width: 0;">
                                                    <h6 class="mb-0 fw-bold text-truncate small" style="max-width: 110px;"><%= expense.description %></h6>
                                                    <span class="text-secondary d-block" style="font-size: 0.7rem;">
                                                        <%= expense.splitType === 'Settlement' ? 'Incoming Credit' : (expense.splitType !== 'None' ? `Split Bill • ${expense.category}` : expense.category) %>
                                                    </span>
                                                </div>
                                            </div>
                                            <div class="d-flex align-items-center gap-2">
                                                <% if(expense.splitType === 'Settlement') { %>
                                                    <span class="fw-bold text-success small">+₹<%= expense.amount %></span>
                                                <% } else { %>
                                                    <span class="fw-bold text-primary small">₹<%= expense.amount %></span>
                                                <% } %>
                                                <form action="/expenses/<%= expense._id %>/delete" method="POST" class="m-0 p-0" onsubmit="return confirm('Delete this record entry?');">
                                                    <button type="submit" class="btn btn-sm btn-link text-danger p-0 border-0">
                                                        <i class="bi bi-trash3-fill fs-6 opacity-75"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    <% }) %>

                                </div>
                            </div>

                            <div class="col-md-6 d-flex flex-column align-items-center justify-content-center border rounded-3 p-3 bg-body shadow-sm">
                                <h6 class="fw-bold quiet text-secondary small text-uppercase tracking-wider mb-2 align-self-start">Sectors</h6>
                                <div style="position: relative; width: 100%; max-width: 190px; margin: 0 auto;">
                                    <canvas id="sectorPieChart"></canvas>
                                </div>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="text-center py-5 my-3 text-secondary">
                            <i class="bi bi-receipt display-5 d-block mb-3 opacity-50"></i>
                            <p class="m-0 fw-medium">Your transactional ledger is empty.</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="col-xl-5 col-lg-12">
            <div class="row g-4">
                
                <div class="col-12">
                    <div class="card border shadow-sm" style="background-color: var(--finmate-card-bg); border-radius: 16px;">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <h5 class="fw-bold m-0" style="color: var(--finmate-purple-heading);">2. Friend Circle & Splitter</h5>
                                    <small class="text-secondary">Peer-to-peer circle debt settlements</small>
                                </div>
                                <div class="d-flex gap-2">
                                    <button class="btn btn-finmate-outline btn-sm px-3 d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#splitBillModal">
                                        <i class="bi bi-pie-chart-fill"></i> Split Bill
                                    </button>
                                    <button class="btn btn-finmate-outline btn-sm px-3 d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#manageCircleModal">
                                        <i class="bi bi-person-plus-fill"></i> Manage Circle
                                    </button>
                                </div>
                            </div>
                            
                            <% if (typeof pendingDebts !== 'undefined' && pendingDebts.length > 0) { %>
                                <div class="mb-4 mt-2">
                                    <h6 class="small fw-bold text-uppercase tracking-wider mb-2" style="color: var(--finmate-purple-heading);"><i class="bi bi-exclamation-circle-fill"></i> Pending Lending Requests</h6>
                                    <div class="d-flex flex-column gap-2">
                                        <% pendingDebts.forEach(debt => { %>
                                            <div class="p-3 border rounded-3 d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-2 shadow-sm" style="background-color: var(--finmate-card-bg); border-color: var(--finmate-purple-sub) !important;">
                                                <div>
                                                    <p class="m-0 small fw-medium" style="color: var(--finmate-text);"><%= debt.message %></p>
                                                    <span class="text-secondary d-block mt-1" style="font-size: 0.7rem;"><%= new Date(debt.createdAt).toLocaleDateString() %></span>
                                                </div>
                                                <div class="d-flex gap-2 align-self-end align-self-sm-center">
                                                    <form action="/debts/<%= debt._id %>/accept" method="POST" class="m-0 p-0">
                                                        <button type="submit" class="btn btn-sm btn-finmate-solid px-3 py-1 fw-medium text-xs" style="font-size: 0.75rem;">Approve & Pay</button>
                                                    </form>
                                                    <form action="/debts/<%= debt._id %>/decline" method="POST" class="m-0 p-0">
                                                        <button type="submit" class="btn btn-sm btn-finmate-outline px-3 py-1 text-xs" style="font-size: 0.75rem;">Decline</button>
                                                    </form>
                                                </div>
                                            </div>
                                        <% }) %>
                                    </div>
                                </div>
                            <% } %>

                            <div class="mt-3">
                                <h6 class="fw-bold small text-secondary text-uppercase tracking-wider mb-2">My Circle</h6>
                                <% if(typeof populatedUser !== 'undefined' && populatedUser.friends && populatedUser.friends.length > 0) { %>
                                    <div class="d-flex flex-wrap gap-2">
                                        <% populatedUser.friends.forEach(friend => { %>
                                            <% if(friend && friend.username) { %>
                                                <span class="badge border px-3 py-2 rounded-pill fw-medium d-flex align-items-center gap-2 shadow-sm" style="background-color: var(--finmate-nav-bg); color: var(--finmate-text); border-color: var(--finmate-border) !important;">
                                                    <i class="bi bi-person-circle text-primary"></i> 
                                                    <span><%= friend.username %></span>
                                                    
                                                    <form action="/remove-friend" method="POST" class="d-inline m-0 p-0 ms-1" onsubmit="return confirm('Remove <%= friend.username %> from your circle?');">
                                                        <input type="hidden" name="friendId" value="<%= friend._id %>">
                                                        <button type="submit" class="bg-transparent border-0 p-0 m-0 d-inline-flex align-items-center text-danger" style="cursor: pointer; font-size: 0.9rem;">
                                                            <i class="bi bi-x-circle-fill text-danger opacity-75"></i>
                                                        </button>
                                                    </form>
                                                </span>
                                            <% } %>
                                        <% }) %>
                                    </div>
                                <% } else { %>
                                    <div class="p-4 border border-dashed rounded-3 bg-body text-center">
                                        <p class="text-secondary small mb-0">Your circle is empty. Click "Manage Circle" to find campus peers.</p>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- MODULE 3: TRANSIT RADAR -->
                <div class="col-md-6 col-12">
                    <div class="card border shadow-sm h-100" style="background-color: var(--finmate-card-bg); border-radius: 16px;">
                        <div class="card-body p-4 d-flex flex-column justify-content-between">
                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h5 class="fw-bold m-0" style="color: var(--finmate-purple-heading);">3. Transit Radar</h5>
                                    <i class="bi bi-car-front-fill fs-4 text-primary"></i>
                                </div>
                                <small class="text-secondary d-block">Split Auto/Cab fares</small>
                            </div>
                            
                            <% if (typeof activeTransits !== 'undefined' && activeTransits.length > 0) { %>
                                <div class="p-3 border rounded-3 mb-3" style="background-color: var(--finmate-nav-bg); border-color: var(--finmate-border) !important;">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="small fw-medium text-secondary">Active Rides:</span>
                                        <span class="badge bg-finmate-solid rounded-pill px-3 py-1 text-xs" style="background-color: var(--finmate-purple-heading) !important; color:#fff !important;"><%= activeTransits.length %> Open</span>
                                    </div>
                                </div>
                                <a href="/transit" class="btn btn-finmate-outline btn-sm w-100 fw-bold rounded-pill">Find a Ride</a>
                            <% } else { %>
                                <div class="p-3 border border-dashed rounded-3 bg-body text-center my-2">
                                    <p class="small text-secondary mb-2">No rides scheduled.</p>
                                    <a href="/transit" class="btn btn-finmate-solid btn-sm px-4 rounded-pill">Host a Ride</a>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- MODULE 4: FOOD POOL CARTS -->
                <div class="col-md-6 col-12">
                    <div class="card border shadow-sm h-100" style="background-color: var(--finmate-card-bg); border-radius: 16px;">
                        <div class="card-body p-4 d-flex flex-column justify-content-between">
                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h5 class="fw-bold m-0" style="color: var(--finmate-purple-heading);">4. Pool Carts</h5>
                                    <i class="bi bi-lightning-charge-fill fs-4 text-primary"></i>
                                </div>
                                <small class="text-secondary d-block">Co-pool to hit minimum delivery values</small>
                            </div>
                            
                            <% if (typeof activeLobbies !== 'undefined' && activeLobbies.length > 0) { %>
                                <div class="p-3 border rounded-3 mb-3" style="background-color: var(--finmate-nav-bg); border-color: var(--finmate-border) !important;">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="small fw-medium text-secondary">Active Pools:</span>
                                        <span class="badge bg-finmate-solid rounded-pill px-3 py-1 text-xs" style="background-color: var(--finmate-purple-heading) !important; color:#fff !important;"><%= activeLobbies.length %> Lobbies Open</span>
                                    </div>
                                </div>
                                <a href="/lobbies" class="btn btn-finmate-outline btn-sm w-100 fw-bold rounded-pill">Enter Lobbies</a>
                            <% } else { %>
                                <div class="p-3 border border-dashed rounded-3 bg-body text-center my-2">
                                    <p class="small text-secondary mb-2">No delivery pool lobbies nearby.</p>
                                    <a href="/lobbies" class="btn btn-finmate-solid btn-sm px-4 rounded-pill">Create Lobby</a>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- MODALS -->
<div class="modal fade" id="addExpenseModal" tabindex="-1" aria-labelledby="addExpenseModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background-color: var(--finmate-card-bg); border-radius: 16px; border: 1px solid var(--finmate-border);">
            <div class="modal-header border-bottom">
                <h5 class="modal-title fw-bold" id="addExpenseModalLabel" style="color: var(--finmate-purple-heading);">Record Personal Outlay</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="/expenses" method="POST">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="description" class="form-label small fw-medium">Description</label>
                        <input type="text" class="form-control" id="description" name="description" placeholder="e.g., Canteen cold drinks" required style="border-radius: 8px;">
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label for="amount" class="form-label small fw-medium">Amount (₹)</label>
                            <input type="number" class="form-control" id="amount" name="amount" min="1" placeholder="0" required style="border-radius: 8px;">
                        </div>
                        <div class="col-6">
                            <label for="category" class="form-label small fw-medium">Category</label>
                            <select class="form-select" id="category" name="category" required style="border-radius: 8px;">
                                <option value="Canteen">Canteen</option>
                                <option value="Academics">Academics</option>
                                <option value="Travel">Travel</option>
                                <option value="Junk Food">Junk Food</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top">
                    <button type="button" class="btn btn-finmate-outline btn-sm px-3" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-finmate-solid btn-sm px-4">Save Entry</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="splitBillModal" tabindex="-1" aria-labelledby="splitBillModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background-color: var(--finmate-card-bg); border-radius: 16px; border: 1px solid var(--finmate-border);">
            <div class="modal-header border-bottom">
                <h5 class="modal-title fw-bold" style="color: var(--finmate-purple-heading);"><i class="bi bi-pie-chart-fill"></i> Circle Bill Splitter</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="/expenses" method="POST">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="splitDescription" class="form-label small fw-medium">Group Outlay Description</label>
                        <input type="text" class="form-control" id="splitDescription" name="description" placeholder="e.g., Canteen samosa treat" required style="border-radius: 8px;">
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label for="splitAmount" class="form-label small fw-medium">Total Bill Amount (₹)</label>
                            <input type="number" class="form-control" id="splitAmount" name="amount" min="1" placeholder="0" required style="border-radius: 8px;">
                        </div>
                        <div class="col-6">
                            <label for="splitCategory" class="form-label small fw-medium">Category</label>
                            <select class="form-select" id="splitCategory" name="category" required style="border-radius: 8px;">
                                <option value="Canteen">Canteen</option>
                                <option value="Junk Food">Junk Food</option>
                                <option value="Travel">Travel</option>
                                <option value="Academics">Academics</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-medium">Splitting Protocol</label>
                        <select class="form-select" id="splitTypeSelect" name="splitType" style="border-radius: 8px;">
                            <option value="Equi-Split">Equi-Split (Equal Division)</option>
                            <option value="Custom Split">Custom Split (Manual Amounts)</option>
                        </select>
                    </div>

                    <h6 class="fw-bold small text-secondary text-uppercase tracking-wider mt-4 mb-2">Select Members & Allocate Shares</h6>
                    <div class="border rounded-3 p-3 bg-body overflow-auto" style="max-height: 220px;">
                        <% if(typeof populatedUser !== 'undefined' && populatedUser.friends && populatedUser.friends.length > 0) { %>
                            <% populatedUser.friends.forEach(friend => { %>
                                <div class="form-check d-flex flex-column mb-3 pb-2 border-bottom last-border-0">
                                    <div class="d-flex align-items-center justify-content-between w-100">
                                        <label class="form-check-label small fw-medium" for="check_<%= friend._id %>">
                                            <input class="form-check-input style-purple-checkbox me-2 friend-selector-checkbox" type="checkbox" name="selectedFriends" value="<%= friend._id %>" id="check_<%= friend._id %>" data-id="<%= friend._id %>">
                                            <%= friend.username %>
                                        </label>
                                        <span class="badge bg-light text-dark border hidden-calc-pill" id="calc_badge_<%= friend._id %>" style="display:none;">₹0</span>
                                    </div>
                                    <div class="mt-2 custom-input-wrapper-box" id="wrapper_<%= friend._id %>" style="display: none;">
                                        <div class="input-group input-group-sm">
                                            <span class="input-group-text">₹</span>
                                            <input type="number" class="form-control custom-share-input-field" name="customAmounts[<%= friend._id %>]" placeholder="Owed share" min="0" data-id="<%= friend._id %>">
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p class="text-center text-muted small m-0 py-2">Add friends to your circle first to populate this section.</p>
                        <% } %>
                    </div>
                </div>
                <div class="modal-footer border-top">
                    <button type="button" class="btn btn-finmate-outline btn-sm px-3" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-finmate-solid btn-sm px-4">Dispatch Split</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="addFundsModal" tabindex="-1" aria-labelledby="addFundsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content" style="background-color: var(--finmate-card-bg); border-radius: 16px; border: 1px solid var(--finmate-border);">
            <div class="modal-header border-bottom">
                <h5 class="modal-title fw-bold" id="addFundsModalLabel" style="color: var(--finmate-purple-heading);">Deposit Allowance</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="/add-funds" method="POST">
                <div class="modal-body">
                    <div class="mb-1">
                        <label for="fundingAmount" class="form-label small fw-medium">Amount to Add (₹)</label>
                        <input type="number" class="form-control" id="fundingAmount" name="fundingAmount" min="1" placeholder="e.g., 2000" required style="border-radius: 8px;">
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-finmate-outline btn-sm px-3" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-finmate-solid btn-sm px-4">Confirm Topup</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="manageCircleModal" tabindex="-1" aria-labelledby="manageCircleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background-color: var(--finmate-card-bg); border-radius: 16px; border: 1px solid var(--finmate-border);">
            <div class="modal-header border-bottom">
                <h5 class="modal-title fw-bold" style="color: var(--finmate-purple-heading);">Campus Directory Search</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="input-group mb-4 shadow-sm">
                    <span class="input-group-text bg-body border-end-0"><i class="bi bi-search text-secondary"></i></span>
                    <input type="text" class="form-control border-start-0" id="friendSearchInput" placeholder="Search by username..." autocomplete="off">
                </div>
                
                <h6 class="fw-bold small text-secondary text-uppercase tracking-wider mb-3">Search Results</h6>
                <div id="searchResultsContainer" class="d-flex flex-column gap-2">
                    <div class="text-center py-4 text-muted small border border-dashed rounded-3 bg-body" id="emptySearchState">
                        Start typing to find peers on campus.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const splitTypeSelect = document.getElementById('splitTypeSelect');
        const splitAmountInput = document.getElementById('splitAmount');
        const checkboxes = document.querySelectorAll('.friend-selector-checkbox');
        
        const updateSplitCalculations = () => {
            const mode = splitTypeSelect.value;
            const totalBill = parseFloat(splitAmountInput.value) || 0;
            const checkedBoxes = Array.from(checkboxes).filter(c => c.checked);
            
            checkboxes.forEach(cb => {
                const friendId = cb.dataset.id;
                const badge = document.getElementById(`calc_badge_${friendId}`);
                const wrapper = document.getElementById(`wrapper_${friendId}`);
                
                if (mode === 'Equi-Split') {
                    wrapper.style.display = 'none';
                    if (cb.checked) {
                        const individualShare = Math.round((totalBill / (checkedBoxes.length + 1)) * 100) / 100;
                        badge.textContent = `₹${individualShare}`;
                        badge.style.display = 'inline-block';
                    } else {
                        badge.style.display = 'none';
                    }
                } else if (mode === 'Custom Split') {
                    badge.style.display = 'none';
                    if (cb.checked) {
                        wrapper.style.display = 'block';
                    } else {
                        wrapper.style.display = 'none';
                        wrapper.querySelector('.custom-share-input-field').value = '';
                    }
                }
            });
        };

        splitTypeSelect.addEventListener('change', updateSplitCalculations);
        splitAmountInput.addEventListener('input', updateSplitCalculations);
        checkboxes.forEach(cb => cb.addEventListener('change', updateSplitCalculations));
    });
</script>

<% if(typeof expenses !== 'undefined' && expenses.length > 0 && analytics) { %>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const dataBridge = document.getElementById('analyticsDataBridge');
        if (!dataBridge) return;

        const ctx = document.getElementById('sectorPieChart').getContext('2d');
        const dataValues = [
            parseFloat(dataBridge.dataset.canteen) || 0,
            parseFloat(dataBridge.dataset.academics) || 0,
            parseFloat(dataBridge.dataset.travel) || 0,
            parseFloat(dataBridge.dataset.junkfood) || 0,
            parseFloat(dataBridge.dataset.other) || 0
        ];

        new Chart(ctx, {
            type: 'pie',
            data: {
                labels: ['Canteen', 'Academics', 'Travel', 'Junk Food', 'Other'],
                datasets: [{
                    data: dataValues,
                    backgroundColor: [ '#9052D4', '#B084E3', '#643199', '#CBB1F0', '#4A2870' ],
                    borderWidth: 1,
                    borderColor: 'var(--finmate-card-bg)'
                }]
            },
            options: {
                plugins: {
                    legend: { position: 'right', labels: { color: 'var(--finmate-text)', boxWidth: 12, font: { size: 10, weight: '500' } } }
                },
                responsive: true,
                maintainAspectRatio: false
            }
        });
    });
</script>
<% } %>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const searchInput = document.getElementById('friendSearchInput');
        const resultsContainer = document.getElementById('searchResultsContainer');
        const emptyState = document.getElementById('emptySearchState');
        let searchTimeout;

        searchInput.addEventListener('input', () => {
            clearTimeout(searchTimeout);
            const query = searchInput.value.trim();

            if (query.length < 2) {
                resultsContainer.innerHTML = '';
                resultsContainer.appendChild(emptyState);
                emptyState.textContent = 'Start typing to find peers on campus.';
                return;
            }

            searchTimeout = setTimeout(async () => {
                try {
                    const response = await fetch(`/search?username=${encodeURIComponent(query)}`);
                    const users = await response.json();
                    resultsContainer.innerHTML = ''; 

                    if (users.length === 0) {
                        const noRes = document.createElement('div');
                        noRes.className = 'text-center py-4 text-muted small border border-dashed rounded-3 bg-body';
                        noRes.textContent = 'No campus mates found with that username.';
                        resultsContainer.appendChild(noRes);
                        return;
                    }

                    users.forEach(user => {
                        const card = document.createElement('div');
                        card.className = 'p-3 border rounded-3 bg-body d-flex justify-content-between align-items-center shadow-sm-hover';
                        card.innerHTML = `
                            <div class="d-flex align-items-center gap-3">
                                <i class="bi bi-person-circle fs-3 text-secondary"></i>
                                <div><h6 class="m-0 fw-bold">${user.username}</h6></div>
                            </div>
                            <button class="btn btn-sm btn-finmate-solid rounded-pill px-3 add-friend-btn" data-id="${user._id}">
                                <i class="bi bi-cursor-fill"></i> Request
                            </button>
                        `;
                        resultsContainer.appendChild(card);
                    });

                    document.querySelectorAll('.add-friend-btn').forEach(btn => {
                        btn.addEventListener('click', async (e) => {
                            const targetBtn = e.currentTarget; // FIX: Store reference to button synchronously
                            const friendId = targetBtn.getAttribute('data-id');
                            const originalHtml = targetBtn.innerHTML;
                            targetBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
                            targetBtn.disabled = true;

                            try {
                                const reqRes = await fetch('/send-friend-request', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ friendId })
                                });
                                
                                const contentType = reqRes.headers.get("content-type");
                                if (!contentType || !contentType.includes("application/json")) {
                                    const textError = await reqRes.text();
                                    throw new Error(textError || "Server returned non-JSON format stack trace.");
                                }

                                const reqData = await reqRes.json();
                                if (reqData.success) {
                                    targetBtn.classList.replace('btn-finmate-solid', 'btn-success');
                                    targetBtn.innerHTML = '<i class="bi bi-check2"></i> Sent';
                                } else {
                                    alert(reqData.error);
                                    targetBtn.innerHTML = originalHtml;
                                    targetBtn.disabled = false;
                                }
                            } catch (err) {
                                alert('Error: ' + err.message);
                                targetBtn.innerHTML = originalHtml;
                                targetBtn.disabled = false;
                            }
                        });
                    });

                } catch (err) { console.error('Search failed', err); }
            }, 300);
        });
    });
</script>