<% layout('layouts/boilerplate') %>

<div class="row justify-content-center">
    <div class="col-md-6 col-xl-4">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h3 class="card-title text-center mb-4 fw-bold">Welcome Back</h3>
                
                <form action="/login" method="POST" novalidate class="needs-validation">
                    <div class="mb-3">
                        <label class="form-label" for="username">Campus Username</label>
                        <input class="form-control" type="text" id="username" name="username" placeholder="Username" required autofocus>
                    </div>

                    <div class="mb-4">
                        <label class="form-label" for="password">Password</label>
                        <input class="form-control" type="password" id="password" name="password" placeholder="••••••••" required>
                    </div>

                    <div class="d-grid">
                        <button class="btn btn-success btn-block fw-bold">Log In</button>
                    </div>
                </form>
                
                <div class="text-center mt-3">
                    <small class="text-muted">New to campus? <a href="/register" class="text-success text-decoration-none">Create an Account</a></small>
                </div>
            </div>
        </div>
    </div>
</div>