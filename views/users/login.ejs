<% layout('layouts/boilerplate') %>

<div class="container d-flex justify-content-center align-items-center my-5 animate-fade-in" style="min-height: 65vh;">
    <div class="card p-4 shadow-sm border" style="width: 100%; max-width: 420px; background-color: var(--finmate-card-bg); border-radius: 12px;">
        <div class="card-body">
            <h2 class="card-title text-center mb-4 fw-bold" style="color: var(--finmate-purple-heading);">Welcome Back</h2>
            
            <form action="/login" method="POST" id="loginForm" novalidate>
                <div class="mb-3">
                    <label for="username" class="form-label small fw-medium">Username</label>
                    <input type="text" class="form-control" id="username" name="username" placeholder="Enter your username" required autofocus style="border-radius: 6px;">
                    <div class="invalid-feedback">Please enter your username.</div>
                </div>

                <div class="mb-4">
                    <label for="password" class="form-label small fw-medium">Password</label>
                    <input type="password" class="form-control" id="password" name="password" placeholder="Enter your password" required style="border-radius: 6px;">
                    <div class="invalid-feedback">Please enter your password.</div>
                </div>

                <button class="btn btn-finmate-solid w-100 d-flex align-items-center justify-content-center gap-2 mb-3" type="submit">
                    <i class="bi bi-box-arrow-in-right" style="color: inherit;"></i> Sign In
                </button>
            </form>

            <div class="text-center mt-4">
                <p class="small text-secondary mb-0">New to the campus? <a href="/register" class="text-decoration-none fw-medium" style="color: var(--finmate-purple-heading);">Create an account</a></p>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const form = document.getElementById('loginForm');
        const inputs = form.querySelectorAll('input');

        // 1. Instantaneous validation as the user types
        inputs.forEach(input => {
            input.addEventListener('input', () => {
                if (input.checkValidity()) {
                    input.classList.remove('is-invalid');
                    input.classList.add('is-valid');
                } else {
                    input.classList.remove('is-valid');
                    input.classList.add('is-invalid');
                }
            });
        });

        // 2. Safe submit handler that doesn't block valid submissions
        form.addEventListener('submit', function (event) {
            if (!form.checkValidity()) {
                event.preventDefault(); // Stop submission ONLY if invalid
                event.stopPropagation();
            }
            // Force visual update on all fields if they hit submit empty
            inputs.forEach(input => {
                if (input.checkValidity()) {
                    input.classList.add('is-valid');
                    input.classList.remove('is-invalid');
                } else {
                    input.classList.add('is-invalid');
                    input.classList.remove('is-valid');
                }
            });
        }, false);
    });
</script>