<% layout('layouts/boilerplate') %>

<div class="container d-flex justify-content-center align-items-center my-5 animate-fade-in" style="min-height: 70vh;">
    <div class="card p-4 shadow-sm border" style="width: 100%; max-width: 450px; background-color: var(--finmate-card-bg); border-radius: 12px;">
        <div class="card-body">
            <h2 class="card-title text-center mb-4 fw-bold" style="color: var(--finmate-purple-heading);">Join FinMate</h2>
            
            <form action="/register" method="POST" id="registerForm" novalidate>
                <div class="mb-3">
                    <label for="username" class="form-label small fw-medium">Username</label>
                    <input type="text" class="form-control" id="username" name="username" placeholder="Choose a unique username" minlength="3" required autofocus style="border-radius: 6px;">
                    <div class="invalid-feedback" id="usernameFeedback">Username must be at least 3 characters.</div>
                </div>

                <div class="mb-3">
                    <label for="email" class="form-label small fw-medium">Campus Email</label>
                    <input type="email" class="form-control" id="email" name="email" placeholder="student@iitbbs.ac.in" required style="border-radius: 6px;">
                    <div class="invalid-feedback" id="emailFeedback">Please enter a valid email format.</div>
                </div>

                <div class="mb-3">
                    <label for="allowance" class="form-label small fw-medium">Initial Monthly Allowance (Optional)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-body-secondary border-end-0" style="border-radius: 6px 0 0 6px; color: var(--finmate-purple-heading);">₹</span>
                        <input type="number" class="form-control border-start-0" id="allowance" name="allowance" placeholder="0" min="0" style="border-radius: 0 6px 6px 0;">
                    </div>
                </div>

                <div class="mb-4">
                    <label for="password" class="form-label small fw-medium">Password</label>
                    <input type="password" class="form-control" id="password" name="password" placeholder="Create a strong password" minlength="6" required style="border-radius: 6px;">
                    <div class="invalid-feedback">Password must be at least 6 characters.</div>
                </div>

                <button class="btn btn-finmate-solid w-100 d-flex align-items-center justify-content-center gap-2 mb-3" type="submit" id="submitBtn">
                    <i class="bi bi-person-plus-fill" style="color: inherit;"></i> Create Account
                </button>
            </form>

            <div class="text-center mt-4">
                <p class="small text-secondary mb-0">Already registered? <a href="/login" class="text-decoration-none fw-medium" style="color: var(--finmate-purple-heading);">Log In here</a></p>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const form = document.getElementById('registerForm');
        const usernameInput = document.getElementById('username');
        const emailInput = document.getElementById('email');
        const passwordInput = document.getElementById('password');
        const allowanceInput = document.getElementById('allowance');

        let usernameTimeout = null;
        let emailTimeout = null;

        // Responsive Username Checking Loop
        usernameInput.addEventListener('input', () => {
            clearTimeout(usernameTimeout);
            const username = usernameInput.value.trim();
            const feedback = document.getElementById('usernameFeedback');

            if (username.length < 3) {
                usernameInput.classList.remove('is-valid');
                usernameInput.classList.add('is-invalid');
                feedback.textContent = "Username must be at least 3 characters.";
                return;
            }

            // Debounce server ping by 300ms to save resources while typing
            usernameTimeout = setTimeout(async () => {
                const response = await fetch(`/check-username?username=${encodeURIComponent(username)}`);
                const data = await response.json();
                
                if (data.exists) {
                    usernameInput.classList.remove('is-valid');
                    usernameInput.classList.add('is-invalid');
                    feedback.textContent = "This username is already taken.";
                } else {
                    usernameInput.classList.remove('is-invalid');
                    usernameInput.classList.add('is-valid');
                }
            }, 300);
        });

        // Responsive Email Checking Loop
        emailInput.addEventListener('input', () => {
            clearTimeout(emailTimeout);
            const email = emailInput.value.trim();
            const feedback = document.getElementById('emailFeedback');
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

            if (!emailRegex.test(email)) {
                emailInput.classList.remove('is-valid');
                emailInput.classList.add('is-invalid');
                feedback.textContent = "Please enter a valid email format.";
                return;
            }

            emailTimeout = setTimeout(async () => {
                const response = await fetch(`/check-email?email=${encodeURIComponent(email)}`);
                const data = await response.json();
                
                if (data.exists) {
                    emailInput.classList.remove('is-valid');
                    emailInput.classList.add('is-invalid');
                    feedback.textContent = "This email is already registered.";
                } else {
                    emailInput.classList.remove('is-invalid');
                    emailInput.classList.add('is-valid');
                }
            }, 300);
        });

        // Standard validation fields fallback bounds
        passwordInput.addEventListener('input', () => {
            if(passwordInput.value.length >= 6) {
                passwordInput.classList.remove('is-invalid');
                passwordInput.classList.add('is-valid');
            } else {
                passwordInput.classList.remove('is-valid');
                passwordInput.classList.add('is-invalid');
            }
        });

        form.addEventListener('submit', function (event) {
            if (!form.checkValidity() || usernameInput.classList.contains('is-invalid') || emailInput.classList.contains('is-invalid')) {
                event.preventDefault();
                event.stopPropagation();
            }
        }, false);
    });
</script>