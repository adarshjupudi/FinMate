<% layout('layouts/boilerplate') %>

<div class="container py-5 animate-fade-in" style="max-width: 1000px;">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <a href="/" class="btn btn-finmate-outline btn-sm px-3 rounded-pill d-flex align-items-center gap-2">
            <i class="bi bi-arrow-left"></i> Dashboard
        </a>
        <h3 class="fw-bold m-0" style="color: var(--finmate-purple-heading);"><i class="bi bi-car-front-fill"></i> Transit Radar</h3>
    </div>

    <div class="row g-4">
        <div class="col-lg-4 col-12">
            <div class="card border shadow-sm" style="background-color: var(--finmate-card-bg); border-radius: 16px; position: sticky; top: 24px;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3" style="color: var(--finmate-purple-heading);">Host a Ride Share</h5>
                    
                    <form action="/transit" method="POST">
                        <div class="mb-3">
                            <label class="form-label small fw-medium">Destination</label>
                            <input type="text" class="form-control" name="destination" placeholder="Railway Station" required style="border-radius: 8px;">
                        </div>
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <label class="form-label small fw-medium">Vehicle</label>
                                <select class="form-select" name="vehicleType" style="border-radius: 8px;">
                                    <option value="Auto">Auto (3 Seats)</option>
                                    <option value="Cab">Cab (4 Seats)</option>
                                </select>
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-medium text-danger">Wait Time (Mins)</label>
                                <input type="number" class="form-control border-danger-subtle" name="duration" value="15" min="1" max="60" required style="border-radius: 8px;">
                            </div>
                        </div>
                        <button type="submit" class="btn btn-finmate-solid w-100 fw-bold rounded-pill mt-2">Broadcast Departure</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-8 col-12">
            <% if (transits && transits.length > 0) { %>
                <div class="d-flex flex-column gap-4">
                    <% transits.forEach(transit => { 
                        const progress = Math.min(Math.round((transit.currentCapacity / transit.targetCapacity) * 100), 100); 
                        const full = transit.currentCapacity >= transit.targetCapacity;
                        
                        const expiryTime = new Date(transit.createdAt).getTime() + (transit.duration * 60000);
                        const minsLeft = Math.max(0, Math.floor((expiryTime - Date.now()) / 60000));

                        // LINTER FIX: Extracting dynamic tags into pure strings
                        const iconHTML = '<i class="bi ' + (transit.vehicleType === 'Auto' ? 'bi-car-front' : 'bi-taxi-front') + '"></i>';
                        const statusHTML = '<span class="fw-bold d-block ' + (full ? 'text-success' : 'text-primary') + '">' + transit.currentCapacity + ' / ' + transit.targetCapacity + ' Seats Filled</span>';
                        const barHTML = '<div class="progress-bar bg-primary" role="progressbar" data-width="' + progress + '"></div>';
                    %>
                        <div class="card border shadow-sm bg-body" style="border-radius: 16px;">
                            <div class="card-header border-bottom bg-transparent p-4 d-flex justify-content-between align-items-start">
                                <div>
                                    <span class="badge bg-primary-subtle text-primary mb-1 rounded-pill">Host: @<%= transit.host.username %></span>
                                    <h4 class="fw-bold m-0 text-dark"><%- iconHTML %> <%= transit.vehicleType %> to <%= transit.destination %></h4>
                                </div>
                                <div class="text-end">
                                    <span class="badge bg-danger rounded-pill mb-1"><i class="bi bi-stopwatch"></i> <%= minsLeft %> Mins Until Departure</span>
                                    <%- statusHTML %>
                                </div>
                            </div>
                            
                            <div class="card-body p-4">
                                <div class="progress mb-4" style="height: 10px; border-radius: 6px; background-color: var(--finmate-border);">
                                    <%- barHTML %>
                                </div>

                                <div class="d-flex flex-column gap-2 mb-4">
                                    <% transit.members.forEach(member => { %>
                                        <div class="p-3 border rounded-3 bg-light-subtle d-flex justify-content-between align-items-center">
                                            <span class="small fw-bold text-dark d-block">@<%= member.user.username %> claimed a seat.</span>
                                            <i class="bi bi-person-fill text-primary"></i>
                                        </div>
                                    <% }) %>
                                </div>

                                <div class="border-top pt-3">
                                    <% if (currentUser._id.toString() === transit.host._id.toString()) { %>
                                        <form action="/transit/<%= transit._id %>/close" method="POST" class="m-0"><button type="submit" class="btn btn-outline-danger btn-sm px-4 w-100 fw-bold rounded-pill">Depart Now</button></form>
                                    <% } else if (full) { %>
                                        <button class="btn btn-secondary btn-sm px-4 w-100 fw-bold rounded-pill" disabled>Ride is Full</button>
                                    <% } else { %>
                                        <form action="/transit/<%= transit._id %>/join" method="POST" class="m-0"><button type="submit" class="btn btn-finmate-solid btn-sm px-4 w-100 fw-bold rounded-pill">Claim a Seat</button></form>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="text-center py-5 border border-dashed bg-body" style="border-radius: 16px;"><p class="text-secondary small">No active transit radars.</p></div>
            <% } %>
        </div>
    </div>
</div>

<script>
document.querySelectorAll('.progress-bar[data-width]').forEach(bar => {
    const width = bar.getAttribute('data-width');
    bar.style.width = width + '%';
    bar.style.backgroundColor = 'var(--finmate-purple-heading)';
});
</script>